# Copy to .env and `source .env` (or export) before deploying / running.

export GOOGLE_CLOUD_PROJECT=your-project-id
export GOOGLE_CLOUD_LOCATION=us-central1

# Set after you create the connector (README step 4). Default: bigquery-3lo
export BIGQUERY_3LO_AUTH_PROVIDER_ID=bigquery-3lo

# GCS bucket used by Agent Runtime for deployment staging (create it first).
export STAGING_BUCKET=gs://your-project-id-agent-staging

# Where the OAuth consent flow redirects (the local frontend). Use localhost.
export CONTINUE_URI=http://localhost:8080/commit

# OAuth scope the user consents to.
export BIGQUERY_SCOPE=https://www.googleapis.com/auth/bigquery
